  <bpmn:collaboration id="Collaboration_0xh2fmy">
    <bpmn:participant id="Participant_0e3gto7" name="Дооснащение" processRef="Process_1p16tp4" />
    <bpmn:textAnnotation id="TextAnnotation_0iam0qq">
      <bpmn:text>Клиент принял работу и забрал автомобиль</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_06otec2" associationDirection="None" sourceRef="Participant_0e3gto7" targetRef="TextAnnotation_0iam0qq" />
    <bpmn:textAnnotation id="TextAnnotation_1g9dwr1">
      <bpmn:text>Хз куда это направлять</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1p6b3i4" associationDirection="None" sourceRef="Participant_0e3gto7" targetRef="TextAnnotation_1g9dwr1" />
    <bpmn:textAnnotation id="TextAnnotation_0hsemyb">
      <bpmn:text>Клиент отказался от приемки автомобиля по причине наличия неисправностей</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1a0ru4g" associationDirection="None" sourceRef="Participant_0e3gto7" targetRef="TextAnnotation_0hsemyb" />
    <bpmn:textAnnotation id="TextAnnotation_1d587jq">
      <bpmn:text>В ходе диагностики был установлен факт невозможности дооснащения конкретной модели автомобиля желаемой системой</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_01h6957" associationDirection="None" sourceRef="Participant_0e3gto7" targetRef="TextAnnotation_1d587jq" />
    <bpmn:textAnnotation id="TextAnnotation_1v9jfeo">
      <bpmn:text>Дооснащение возможно</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0ba2km0" associationDirection="None" sourceRef="Participant_0e3gto7" targetRef="TextAnnotation_1v9jfeo" />
    <bpmn:textAnnotation id="TextAnnotation_1a4sh9v">
      <bpmn:text>В БД нет данных о необходимых запасных частях</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1nfey3q" associationDirection="None" sourceRef="Participant_0e3gto7" targetRef="TextAnnotation_1a4sh9v" />
    <bpmn:textAnnotation id="TextAnnotation_1jj89v1">
      <bpmn:text>В БД есть весь список необходимых запасных частей и оборудования</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0824ibm" associationDirection="None" sourceRef="Participant_0e3gto7" targetRef="TextAnnotation_1jj89v1" />
    <bpmn:textAnnotation id="TextAnnotation_17au0qj">
      <bpmn:text>Отказ в поставке запрошенных запасных частей</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0nk7tqc" associationDirection="None" sourceRef="Participant_0e3gto7" targetRef="TextAnnotation_17au0qj" />
    <bpmn:textAnnotation id="TextAnnotation_1y4obt1">
      <bpmn:text>Некорректный подбор запасных частей</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0rts51f" associationDirection="None" sourceRef="Participant_0e3gto7" targetRef="TextAnnotation_1y4obt1" />
    <bpmn:textAnnotation id="TextAnnotation_1e6lwc2">
      <bpmn:text>Используемое оборудование не справилось с задачей по причине поломки или неверного выбора этого оборудования</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0pfpjme" associationDirection="None" sourceRef="Participant_0e3gto7" targetRef="TextAnnotation_1e6lwc2" />
    <bpmn:textAnnotation id="TextAnnotation_0n4su43">
      <bpmn:text>Отказ в поставке запрошенного оборудования</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1krirgv" associationDirection="None" sourceRef="Participant_0e3gto7" targetRef="TextAnnotation_0n4su43" />
    <bpmn:textAnnotation id="TextAnnotation_0tv87i5">
      <bpmn:text>Невозможно дооснастить</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1ivavdt">
      <bpmn:text>Запчасти и оборудование в наличии</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1e4m8hi" associationDirection="None" sourceRef="Participant_0e3gto7" targetRef="TextAnnotation_1ivavdt" />
    <bpmn:textAnnotation id="TextAnnotation_0o4z8r4">
      <bpmn:text>Недостаточно запчастей или оборудования в наличии</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_12iof9r" associationDirection="None" sourceRef="Flow_00e7zoh" targetRef="TextAnnotation_0o4z8r4" />
    <bpmn:association id="Association_0smwi26" associationDirection="None" sourceRef="TextAnnotation_0tv87i5" targetRef="Flow_07nmuhf" />
    <bpmn:textAnnotation id="TextAnnotation_1fspbeb">
      <bpmn:text>Списка нет в базе</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0h5ie4a" associationDirection="None" sourceRef="Flow_0nlja8w" targetRef="TextAnnotation_1fspbeb" />
    <bpmn:textAnnotation id="TextAnnotation_1tzvm9d">
      <bpmn:text>Списка нет в базе</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1p9awah" associationDirection="None" sourceRef="Flow_07b5quf" targetRef="TextAnnotation_1tzvm9d" />
    <bpmn:textAnnotation id="TextAnnotation_0yv5d4v">
      <bpmn:text>Список оборудования есть в базе</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_12vurc5" associationDirection="None" sourceRef="Flow_0w052bp" targetRef="TextAnnotation_0yv5d4v" />
    <bpmn:textAnnotation id="TextAnnotation_1y1c11f">
      <bpmn:text>Ошибка монтажа</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1yybii6" associationDirection="None" sourceRef="Flow_00l5n2e" targetRef="TextAnnotation_1y1c11f" />
    <bpmn:textAnnotation id="TextAnnotation_0tk59qr">
      <bpmn:text>Ошибка кодирования/калибровки</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1drp0sq" associationDirection="None" sourceRef="Flow_09tujym" targetRef="TextAnnotation_0tk59qr" />
    <bpmn:textAnnotation id="TextAnnotation_0hcol9j">
      <bpmn:text>Список запчастей есть в базе</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0zx0s1i" associationDirection="None" sourceRef="Flow_0vy19vi" targetRef="TextAnnotation_0hcol9j" />
    <bpmn:textAnnotation id="TextAnnotation_09ehcjp">
      <bpmn:text>Все поступило на склад</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1kyusts" associationDirection="None" sourceRef="Flow_1exfwh1" targetRef="TextAnnotation_09ehcjp" />
    <bpmn:textAnnotation id="TextAnnotation_0mz7wwc">
      <bpmn:text>Отказ поставщика/ другие проблемы с поставкой</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0uh1ut8" associationDirection="None" sourceRef="Flow_1ci0pxt" targetRef="TextAnnotation_0mz7wwc" />
    <bpmn:textAnnotation id="TextAnnotation_0txclqd">
      <bpmn:text>Клиент отказался от приемки авто</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0pzlwv3" associationDirection="None" sourceRef="Flow_1bsqy4y" targetRef="TextAnnotation_0txclqd" />
    <bpmn:textAnnotation id="TextAnnotation_1cnjli1">
      <bpmn:text>Система исправна</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0ifpjhz" associationDirection="None" sourceRef="Flow_128rqxf" targetRef="TextAnnotation_1cnjli1" />
    <bpmn:textAnnotation id="TextAnnotation_1bmbjsk">
      <bpmn:text>Система неисправна</bpmn:text>
